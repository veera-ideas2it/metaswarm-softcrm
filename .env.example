# =============================================================================
# SoftCRM Environment Variables
# Copy this file to .env and fill in all REQUIRED values before running.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (REQUIRED)
# -----------------------------------------------------------------------------
# Name of the database to create / connect to
POSTGRES_DB=softcrm

# Database username
POSTGRES_USER=softcrm

# Database password — use a strong random string in production
POSTGRES_PASSWORD=change_me_in_production

# -----------------------------------------------------------------------------
# Backend — Database URL (REQUIRED)
# Constructed from the Postgres vars above; override only if using an external DB.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://softcrm:change_me_in_production@db:5432/softcrm

# -----------------------------------------------------------------------------
# JWT / Authentication (REQUIRED)
# SECRET_KEY must be a long, random string — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
SECRET_KEY=replace_this_with_a_64_char_random_hex_string

# JWT signing algorithm (OPTIONAL — default: HS256)
ALGORITHM=HS256

# Access token lifetime in minutes (OPTIONAL — default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token lifetime in days (OPTIONAL — default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# CORS (OPTIONAL — default: http://localhost:5174)
# Comma-separated list of allowed frontend origins.
# In production set to your actual frontend domain(s).
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=["http://localhost:5174"]

# -----------------------------------------------------------------------------
# Frontend (Vite) — OPTIONAL
# Vite exposes only variables prefixed with VITE_ to the browser bundle.
# -----------------------------------------------------------------------------
# URL the frontend uses to reach the backend API
# Only needed when running the frontend outside Docker (direct npm run dev).
# In Docker, leave this unset — the Vite proxy routes /api/* to the backend container.
# VITE_API_BASE_URL=http://localhost:8000
